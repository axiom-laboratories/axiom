# Master of Puppets — Environment Variables Reference
# Copy this file to .env and fill in the required values before starting the stack.

# === Required ===

# JWT signing secret. Falls back to a weak hardcoded dev value if absent — tokens are insecure without this.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Fernet key for encrypting secrets at rest. Auto-generates an ephemeral key if absent — secrets are lost on container restart.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# Shared API key for legacy API key auth. No default — the process crashes at import if this is absent.
API_KEY=

# Initial admin account password. Only read on first start (when the admin user does not yet exist in the DB).
# Set this to something strong before the first boot.
ADMIN_PASSWORD=

# === Database ===

# Default is SQLite (dev only). Use PostgreSQL in production.
# "db" is the Compose service name from compose.server.yaml.
DATABASE_URL=postgresql+asyncpg://puppet:password@db/puppet_db

# === Optional ===

# Public URL of the puppeteer service, embedded in node join tokens. Defaults to https://localhost:8001.
# AGENT_URL=https://your-host

# Node image used in Foundry-generated compose files.
# NODE_IMAGE=your-registry/puppet-node:latest

# Container runtime for puppet nodes. Choices: auto | direct | docker | podman
# NODE_EXECUTION_MODE=auto

# Axiom licence key. Leave blank for Community Edition; paste an EE licence key here to unlock EE features.
# AXIOM_LICENCE_KEY=

# === Tunnel ===

# Cloudflare Tunnel token. Required only if running the cloudflared tunnel service.
# CLOUDFLARE_TUNNEL_TOKEN=

# Extra SAN added to the TLS certificate. Used when accessing the dashboard via a custom domain.
# SERVER_HOSTNAME=

# DuckDNS token for automatic DDNS updates. Required only if using the DDNS update service.
# DUCKDNS_TOKEN=
