# Master of Puppets - Environment Variables Template
# Copy this to .env and fill in the values

# Agent Admin Password
ADMIN_PASSWORD=

# Security Keys (Generate strong random strings)
API_KEY=
ENCRYPTION_KEY=
JWT_SECRET=

# Database Connection (if using Postgres)
# DB_PASSWORD=

# Mirror Configuration
MIRROR_DATA_PATH=/app/mirror_data
PYPI_MIRROR_URL=http://pypi:8080/simple
APT_MIRROR_URL=http://mirror/apt
