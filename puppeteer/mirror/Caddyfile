:80 {
    # APT (Debian) packages at /apt/
    handle /apt/* {
        root /data/apt
        file_server browse
    }

    # Alpine packages at /apk/
    handle /apk/* {
        root /data/apk
        file_server browse
    }

    # PyPI packages at /simple/ (existing)
    handle /simple/* {
        root /data/pypi
        file_server browse
    }

    # Default 404 for unmapped paths
    handle {
        respond 404
    }
}
