# Master of Puppets — Environment Variable Template
# Copy to .env and fill in real values before starting the stack.
# Never commit .env (it is in .gitignore). This file IS safe to commit.

# ── Database ──────────────────────────────────────────────────────────────────
# Postgres connection string for Docker stack. The default below matches
# compose.server.yaml's db service defaults.
DATABASE_URL=postgresql+asyncpg://puppet:masterpassword@db/puppet_db

# Postgres credentials (must match DATABASE_URL above)
POSTGRES_USER=puppet
POSTGRES_PASSWORD=masterpassword
POSTGRES_DB=puppet_db

# ── Security ──────────────────────────────────────────────────────────────────
# JWT signing key — use a long random string in production
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production

# Fernet key for encrypting secrets at rest — MUST be set in production
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# Legacy API key for service-to-service auth (optional)
API_KEY=

# ── Admin ─────────────────────────────────────────────────────────────────────
# Initial admin password seeded on first start (if user doesn't exist in DB).
# Change immediately after first login. DB password is the source of truth for
# existing deployments — changing this value does NOT reset an existing password.
ADMIN_PASSWORD=change-me

# ── Agent / Node ──────────────────────────────────────────────────────────────
# Public URL of the Puppeteer agent service (used by puppet nodes to connect)
AGENT_URL=https://localhost:8001

# Base Docker image for puppet nodes
NODE_IMAGE=localhost/master-of-puppets-node:latest

# Execution mode for node jobs: auto | direct | docker | podman
# Use "direct" for Docker-in-Docker (DinD) environments to avoid cgroup v2 issues
NODE_EXECUTION_MODE=auto

# ── DB Connection Pool ────────────────────────────────────────────────────────
# asyncpg connection pool size for Postgres deployments.
# Tuning formula: pool_size <= max_connections / worker_count
# Default: 20 (sustains 20 concurrent polling nodes).
# max_overflow is hardcoded to 10, pool_recycle to 300s, pool_timeout to 30s.
# Has no effect when DATABASE_URL is SQLite (local dev).
ASYNCPG_POOL_SIZE=20

# ── TLS / DNS ─────────────────────────────────────────────────────────────────
# DuckDNS token and domain for DDNS updates (optional)
DUCKDNS_TOKEN=
DUCKDNS_DOMAIN=

# ACME email for Let's Encrypt cert registration (optional)
ACME_EMAIL=

# Server hostname or IP included as a SAN in the Caddy TLS cert
# Set to your host IP or FQDN so browser clients trust HTTPS
SERVER_HOSTNAME=

# ── Cloudflare Tunnel (optional) ──────────────────────────────────────────────
# Token from Cloudflare Zero Trust → Tunnels (leave blank if not using a tunnel)
TUNNEL_TOKEN=

# ── Enterprise Edition (optional) ─────────────────────────────────────────────
AXIOM_LICENCE_KEY=
