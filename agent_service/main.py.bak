# --- Admin Endpoints ---

@app.post("/admin/generate-token")
async def generate_join_token(api_key: str = Depends(verify_api_key)):
    """Generates a new Join Token for a Node."""
    token = uuid.uuid4().hex
    import time
    with get_db_connection() as conn:
        conn.execute("INSERT INTO tokens (token, created_at) VALUES (?, ?)", (token, time.time()))
        conn.commit()
    return {"token": token}

class KeyUpload(BaseModel):
    key_content: str

@app.post("/admin/upload-key")
async def upload_public_key(req: KeyUpload, api_key: str = Depends(verify_api_key)):
    """Stores the Code Signing Public Key."""
    with get_db_connection() as conn:
        conn.execute("INSERT OR REPLACE INTO config (key, value) VALUES (?, ?)", ("signing_public_key", req.key_content))
        conn.commit()
    return {"status": "stored"}

@app.get("/config/public-key")
async def get_public_key(x_join_token: str = Header(None)):
    """Returns the Public Key. Requires a valid Join Token."""
    # Validate Token
    with get_db_connection() as conn:
        cursor = conn.cursor()
        cursor.execute("SELECT 1 FROM tokens WHERE token = ?", (x_join_token,))
        if not cursor.fetchone():
            # Allow "enrollment-secret" for transition if needed, or strictly blocking.
            # Let's be strict for new flow.
            # But wait, Node calls this BEFORE register.
            # So Node needs the Join Token.
            if x_join_token != "enrollment-secret": # temp fallback
                 raise HTTPException(status_code=403, detail="Invalid Join Token")

        cursor.execute("SELECT value FROM config WHERE key = ?", ("signing_public_key",))
        row = cursor.fetchone()
        if not row:
            raise HTTPException(status_code=404, detail="Key not found")
        return {"public_key": row[0]}

